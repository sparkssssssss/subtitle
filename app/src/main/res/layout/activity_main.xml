<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101418"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="字幕下载"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="源：zimuku.org　保存：Download/subtitle/"
        android:textColor="#AAB4BE"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/button_bg"
            android:hint="输入影片名 / 剧集名"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textColorHint="#7C8792"
            android:textSize="18sp" />

        <Button
            android:id="@+id/searchButton"
            android:layout_width="130dp"
            android:layout_height="52dp"
            android:layout_marginLeft="12dp"
            android:background="@drawable/button_bg"
            android:text="搜索"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/filesButton"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:background="@drawable/button_bg"
            android:text="本地文件"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/clearButton"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:layout_marginLeft="12dp"
            android:background="@drawable/button_bg"
            android:text="清空目录"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="输入关键词后按确定键搜索。"
        android:textColor="#D6DEE6"
        android:textSize="16sp" />

    <ListView
        android:id="@+id/resultList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="#101418"
        android:cacheColorHint="#00000000"
        android:choiceMode="none"
        android:divider="#303A44"
        android:dividerHeight="1dp"
        android:focusable="true" />
</LinearLayout>
